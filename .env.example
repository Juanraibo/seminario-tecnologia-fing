# EcoFIng — Variables de entorno
# Copiar este archivo como app/.env.local y completar los valores
# NUNCA commitear archivos .env con credenciales reales

# ── OpenRouter API (clasificación de imágenes con IA) ──────────────
# Obtener en: https://openrouter.ai/keys
# Usado en: HU-E02 (Clasificación automática de RAEE con IA)
VITE_OPENROUTER_API_KEY=sk-or-v1-...tu-api-key...
VITE_OPENROUTER_MODEL=anthropic/claude-3-haiku

# ── Supabase (base de datos PostgreSQL) ────────────────────────────
# Obtener en: Supabase Dashboard → Project Settings → API
# URL del proyecto y Anon/Public Key
VITE_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Climatiq API (cálculo de CO2 evitado) ───────────────────────────
# Obtener en: https://app.climatiq.io/
# Usado en: Componente ImpactoAmbiental y Calculadora
VITE_CLIMATIQ_API_KEY=tu-climatiq-api-key-aqui
