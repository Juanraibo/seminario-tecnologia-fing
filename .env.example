# EcoFIng — Variables de entorno
# Copiar este archivo como .env.local y completar los valores
# NUNCA commitear .env.local

# API Key de OpenRouter (para clasificación de imágenes con IA en HU-E02)
# Obtener en: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=sk-or-...tu-api-key-aqui...

# Supabase (base de datos PostgreSQL)
# Obtener en: Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Climatiq API (cálculo de CO2)
# Obtener en: https://app.climatiq.io/
VITE_CLIMATIQ_API_KEY=tu-climatiq-api-key-aqui
